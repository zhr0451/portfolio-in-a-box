---
import AvailabilityBar from "../components/sections/AvailabilityBar.astro";
import EducationSection from "../components/sections/EducationSection.astro";
import ExperienceSection from "../components/sections/ExperienceSection.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import ProjectsSection from "../components/sections/ProjectsSection.astro";
import SiteFooter from "../components/sections/SiteFooter.astro";
import SkillsSection from "../components/sections/SkillsSection.astro";
import { site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title={site.meta.title} description={site.meta.description} locale="en">
  <main class="portfolio-shell">
    <HeroSection
      person={site.person}
      hero={site.hero}
      localeLabels={site.localeLabels}
      actions={site.actions}
    />
    <ExperienceSection items={site.experiences} />
    <EducationSection items={site.education} />
    <SkillsSection groups={site.skillGroups} />
    <ProjectsSection groups={site.projectGroups} />
    <AvailabilityBar availability={site.person.availability} />
    <SiteFooter name={site.person.name} year={site.person.footerYear} />
  </main>

  <script is:inline>
    (() => {
      const storageKey = "portfolio-lang";
      const root = document.documentElement;
      const controls = Array.from(document.querySelectorAll("[data-switch-lang]"));
      const allowed = new Set(["ru", "en"]);

      const applyLang = (lang) => {
        if (!allowed.has(lang)) return;
        root.lang = lang;
        root.dataset.lang = lang;
        controls.forEach((control) => {
          const isActive = control.getAttribute("data-switch-lang") === lang;
          control.classList.toggle("is-active", isActive);
          control.setAttribute("aria-pressed", String(isActive));
        });
      };

      const initialLang = localStorage.getItem(storageKey) || root.dataset.lang || "en";
      applyLang(initialLang);

      controls.forEach((control) => {
        control.addEventListener("click", () => {
          const nextLang = control.getAttribute("data-switch-lang");
          if (!nextLang) return;
          localStorage.setItem(storageKey, nextLang);
          applyLang(nextLang);
        });
      });
    })();
  </script>
</BaseLayout>
