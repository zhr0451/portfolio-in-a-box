---
interface Props {
  label: string;
  href?: string;
  asset: string;
}

const { label, href = "", asset } = Astro.props;
const isLink = href.trim().length > 0;
const openInNewTab = href.startsWith("http");
---

<div class="action-card">
  {
    isLink ? (
      <a
        class="action-button"
        href={href}
        aria-label={label}
        title={label}
        target={openInNewTab ? "_blank" : undefined}
        rel={openInNewTab ? "noreferrer" : undefined}
      >
        <img src={asset} alt="" aria-hidden="true" loading="lazy" decoding="async" />
        <span class="sr-only">{label}</span>
      </a>
    ) : (
      <span class="action-button is-disabled" aria-hidden="true" title={`${label} link is not public yet`}>
        <img src={asset} alt="" loading="lazy" decoding="async" />
      </span>
    )
  }
  <p class="action-label">{label}</p>
</div>
