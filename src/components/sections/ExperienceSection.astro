---
interface ExperienceItem {
  place: string;
  period: string;
}

interface Props {
  items: readonly ExperienceItem[];
}

const { items } = Astro.props;
---

<section class="panel experience-panel">
  <p class="section-title">
    <span data-lang-content="en">Experience</span>
    <span data-lang-content="ru">Опыт</span>
  </p>
  <div class="experience-list">
    {
      items.map((experience) => (
        <div class="inner-panel experience-row">
          <p class="experience-place">{experience.place}</p>
          <p class="experience-period">{experience.period}</p>
        </div>
      ))
    }
  </div>
</section>
