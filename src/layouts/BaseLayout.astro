---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  locale?: "ru" | "en";
}

const {
  title = "Zakhar Samokhvalov | Game Design & System Administration Portfolio",
  description = "Portfolio of Zakhar Samokhvalov, a game designer and system administrator focused on indie games, Linux administration, and frontend craft.",
  locale = "en",
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
const previewImage = Astro.site
  ? new URL(`${baseUrl}media/photo_2026-03-15_19-53-33.jpg`, Astro.site).href
  : `${baseUrl}media/photo_2026-03-15_19-53-33.jpg`;
---

<!doctype html>
<html lang={locale} data-lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content="Zakhar Samokhvalov" />
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl.href} />}
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}media/favicon.svg`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl.href} />}
    <meta property="og:image" content={previewImage} />
    <meta property="og:site_name" content="Zakhar Samokhvalov Portfolio" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={previewImage} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
